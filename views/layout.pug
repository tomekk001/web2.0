doctype html
html(lang="pl")
  head
    title= title
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous")
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container-fluid
        a.navbar-brand(href="/") Moja Aplikacja Web 2.0
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
          span.navbar-toggler-icon
        .collapse.navbar-collapse#navbarNav
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href="/") Strona Główna
            if user
              li.nav-item
                a.nav-link(href="/books") 📚 Biblioteka
            if user && user.isAdmin
              li.nav-item
                a.nav-link(href="/admin" style="color: gold; font-weight: bold;") 🛡️ PANEL ADMINISTRATORA
          ul.navbar-nav
            if user
              li.nav-item.dropdown
                a.nav-link.dropdown-toggle(href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                  = user.username
                ul.dropdown-menu(aria-labelledby="userDropdown")
                  li
                    a.dropdown-item(href="/auth/logout") Wyloguj
                  li
                    a.dropdown-item(href="/change-password") Zmień hasło
            else
              li.nav-item
                a.nav-link(href="/auth/login") Logowanie
              li.nav-item
                a.nav-link(href="/auth/register") Rejestracja
    main.container.mt-4
      block content
    footer.bg-light.text-center.text-muted.mt-5.py-3
      .container
        p.mb-0 Zrealizowano w ramach sprawozdania 1
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous")